<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<title>Cupom</title>

<style>

body{

font-family: monospace;
width:300px;
margin:auto;

}

h2{

text-align:center;

}

hr{

border-top:1px dashed black;

}

.item{

display:flex;
justify-content:space-between;

}

.total{

font-size:18px;
font-weight:bold;
text-align:right;

}

button{

margin-top:20px;
padding:10px;
width:100%;

}

</style>

</head>

<body>

<h2>CYBER PDV</h2>

<p style="text-align:center">

Rua Exemplo 123<br>
CNPJ: 00.000.000/0001-00

</p>

<hr>

<p>Data: <%= new Date().toLocaleString() %></p>

<hr>

<p>Itens da venda</p>

<% itens.forEach(function(i){ %>

<div class="item">

<span><%= i.produto %> x<%= i.quantidade %></span>

<span>R$ <%= i.total %></span>

</div>

<% }) %>

<hr>

<p class="total">

TOTAL: R$ <%= total %>

</p>

<p>

Pagamento: <%= pagamento %>

</p>

<hr>

<p style="text-align:center">

Obrigado pela preferência

</p>

<button onclick="window.print()">

Imprimir Cupom

</button>

</body>

</html>