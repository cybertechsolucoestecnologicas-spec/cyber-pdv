<h1>📊 Dashboard</h1>

<div class="cards">

    <div class="card">
        <h2><%= totalProdutos || 0 %></h2>
        <p>Produtos</p>
    </div>

    <div class="card">
        <h2>R$ <%= (totalVendas || 0).toFixed(2) %></h2>
        <p>Vendas</p>
    </div>

    <div class="card">
        <h2><%= (estoqueBaixo || []).length %></h2>
        <p>Estoque Baixo</p>
    </div>

</div>

<h2>Estoque baixo</h2>

<table>
<tr>
<th>Produto</th>
<th>Qtd</th>
</tr>

<% (estoqueBaixo || []).forEach(p => { %>
<tr>
<td><%= p.nome %></td>
<td class="low"><%= p.quantidade %></td>
</tr>
<% }) %>

</table>