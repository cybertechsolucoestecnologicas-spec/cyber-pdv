<!DOCTYPE html>
<html>
<head>
    <title>Caixa</title>
</head>
<body style="background:#0f172a;color:white;padding:20px">

    <h1>💰 Caixa</h1>

    <% if (!caixa) { %>

        <h2>Abrir Caixa</h2>
        <form method="POST" action="/caixa/abrir">
            <input name="valor" placeholder="Saldo inicial" required>
            <button>Abrir Caixa</button>
        </form>

    <% } else { %>

        <h2>Caixa Aberto</h2>

        <p>Saldo inicial: R$ <%= caixa.saldo_inicial %></p>

        <form method="POST" action="/caixa/fechar">
            <button>Fechar Caixa</button>
        </form>

    <% } %>

    <br>
    <a href="/">⬅ Voltar</a>

</body>
</html>