<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Caixa</title>
</head>
<body>

<h1>💰 Controle de Caixa</h1>

<% if(!caixa){ %>

<h2>Abrir Caixa</h2>

<form action="/abrir-caixa" method="POST">
    <input type="number" step="0.01" name="valor" placeholder="Valor inicial" required>
    <button type="submit">Abrir Caixa</button>
</form>

<% } else { %>

<h2>Caixa Aberto</h2>

<p>Valor inicial: R$ <%= caixa.valor_inicial %></p>

<form action="/fechar-caixa" method="POST">
    <button type="submit">Fechar Caixa</button>
</form>

<% } %>

<br>
<a href="/dashboard">⬅ Voltar</a>

</body>
</html>