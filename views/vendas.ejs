<h1>PDV</h1>

<input id="codigo" placeholder="Código" autofocus>

<ul id="lista"></ul>

<h2>Total: <span id="total">0</span></h2>

<button onclick="finalizar()">Finalizar</button>

<script>
let carrinho = [];
let total = 0;

document.getElementById("codigo").addEventListener("keypress", async e => {
    if (e.key === "Enter") {
        let cod = e.target.value;

        let res = await fetch("/api/produtos/" + cod);
        let p = await res.json();

        if (p.erro) return alert("Produto não encontrado");

        carrinho.push({ id: p.id, nome: p.nome, preco: p.preco, qtd: 1 });

        total += parseFloat(p.preco);

        atualizar();

        e.target.value = "";
    }
});

function atualizar() {
    let lista = document.getElementById("lista");
    lista.innerHTML = "";

    carrinho.forEach(p => {
        lista.innerHTML += `<li>${p.nome} - R$ ${p.preco}</li>`;
    });

    document.getElementById("total").innerText = total.toFixed(2);
}

async function finalizar() {
    await fetch("/api/venda", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ itens: carrinho, total })
    });

    alert("Venda finalizada!");
    location.reload();
}
</script>