<link rel="stylesheet" href="/css/caixa.css">

<div class="container">

<div class="card">
<form method="POST">
<input name="nome" placeholder="Nome">
<input name="preco" placeholder="Preço">
<button>Salvar</button>
</form>
</div>

<div class="card">
<ul>
<% produtos.forEach(p => { %>
<li><%= p.nome %> - R$ <%= p.preco %></li>
<% }) %>
</ul>
</div>

</div>