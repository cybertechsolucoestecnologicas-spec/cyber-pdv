<link rel="stylesheet" href="/css/style.css">

<div class="container">

<div class="card">
<h2>Novo Produto</h2>

<form method="POST">
<input name="nome" placeholder="Nome">
<input name="preco" placeholder="Preço">
<button>Salvar</button>
</form>

</div>

<div class="card">
<h2>Lista</h2>

<ul>
<% produtos.forEach(p => { %>
<li><%= p.nome %> - R$ <%= p.preco %></li>
<% }) %>
</ul>

</div>

</div>