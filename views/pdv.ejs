<!DOCTYPE html>
<html>
<head>
    <title>PDV</title>
</head>
<body style="background:#0b1a2f; color:white; font-family:Arial;">

<h2>PDV</h2>

<input id="busca" placeholder="Digite o produto" style="width:300px; padding:10px;">

<ul id="lista"></ul>

<h3>Total: R$ <span id="total">0</span></h3>

<form method="POST" action="/finalizar">
    <input type="hidden" name="total" id="totalInput">
    <button type="submit">Finalizar Venda</button>
</form>

<script>
let produtos = <%- JSON.stringify(produtos) %>;
let carrinho = [];
let total = 0;

const busca = document.getElementById("busca");
const lista = document.getElementById("lista");
const totalSpan = document.getElementById("total");
const totalInput = document.getElementById("totalInput");

// 🔥 DIGITOU E APERTOU ENTER
busca.addEventListener("keypress", function(e) {
    if (e.key === "Enter") {
        e.preventDefault();

        let nome = busca.value.toLowerCase().trim();

        let produto = produtos.find(p =>
            p.nome.toLowerCase().includes(nome)
        );

        if (!produto) {
            alert("Produto não encontrado");
            return;
        }

        carrinho.push(produto);
        total += produto.preco;

        atualizarTela();
        busca.value = "";
    }
});

function atualizarTela() {
    lista.innerHTML = "";

    carrinho.forEach(p => {
        let li = document.createElement("li");
        li.innerText = p.nome + " - R$ " + p.preco;
        lista.appendChild(li);
    });

    totalSpan.innerText = total.toFixed(2);

    // 🔥 ESSENCIAL
    totalInput.value = total;
}
</script>

</body>
</html>