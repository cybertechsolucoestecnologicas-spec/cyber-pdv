.vazioconst sqlite3 = require("sqlite3").verbose();

const db = new sqlite3.Database("./database/pdv.db");

// CRIAR TABELAS
db.serialize(() => {

    db.run(`
        CREATE TABLE IF NOT EXISTS produtos (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            nome TEXT,
            preco REAL
        )
    `);

    db.run(`
        CREATE TABLE IF NOT EXISTS vendas (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            total REAL,
            data TEXT
        )
    `);

});

module.exports = db;
